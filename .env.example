# Shrike AI Lab Environment Variables
# Copy to .env and fill in your values

# ===========================================
# LiteLLM Configuration
# ===========================================
# Master key for API authentication (can be any string for local use)
LITELLM_MASTER_KEY=sk-shrike-local

# ===========================================
# Cloud API Keys (Optional - for fallback)
# ===========================================
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Get from: https://platform.openai.com/
OPENAI_API_KEY=

# ===========================================
# GPU Configuration
# ===========================================
# Your RTX card's VRAM (8GB for 2080, 11GB for 2080 Ti)
OLLAMA_GPU_MEMORY=8GB

# ===========================================
# SpecPilot Integration
# ===========================================
# URL where SpecPilot backend runs
SPECPILOT_API_URL=http://localhost:8000

# ===========================================
# Training Configuration
# ===========================================
# Where to save fine-tuned models
MODEL_OUTPUT_DIR=./models/finetuned

# Hugging Face token (for downloading gated models)
# Get from: https://huggingface.co/settings/tokens
HF_TOKEN=

# ===========================================
# Data Collection
# ===========================================
# For BillWatch data collection
# Get from: https://api.congress.gov/sign-up/
CONGRESS_API_KEY=

# For GitHub-based data collection
# GITHUB_TOKEN=

# ===========================================
# Remote Access
# ===========================================
# Your local network IP (for access from Mac/Railway)
# Find with: ipconfig (Windows) or ifconfig (Mac/Linux)
HOST_IP=localhost

# If using Tailscale
# TAILSCALE_IP=100.x.x.x

# ===========================================
# Monitoring (Optional)
# ===========================================
# Weights & Biases for training tracking
# WANDB_API_KEY=
