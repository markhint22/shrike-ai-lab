{"test_goal": "Verify that a deleted item is removed from the list without page refresh", "flow_type": "optimistic_ui_update", "setup": "Seed 5 items; capture item ID of item[0]", "assertions": [{"type": "initial_count", "selector": ".bill-card", "expected": 5, "playwright": "await expect(page.locator('.bill-card')).toHaveCount(5)"}, {"type": "click_delete", "playwright": "await page.locator('.bill-card').first().locator('[data-testid=\"delete-btn\"]').click()"}, {"type": "confirm_dialog", "playwright": "await page.locator('[data-testid=\"confirm-delete\"]').click()"}, {"type": "count_after_delete", "selector": ".bill-card", "expected": 4, "playwright": "await expect(page.locator('.bill-card')).toHaveCount(4)"}, {"type": "verify_removed_item_gone", "playwright": "await expect(page.locator('[data-id=\"item-0\"]')).not.toBeAttached()"}]}
{"test_goal": "Verify search input filters list items", "flow_type": "basic_filtering", "assertions": [{"type": "fill_search", "playwright": "await page.fill('[data-testid=\"search-input\"]', 'energy')"}, {"type": "results_visible", "playwright": "await expect(page.locator('[data-testid=\"result-row\"]')).toHaveCount(2)"}, {"type": "contains_term", "playwright": "await expect(page.locator('[data-testid=\"result-row\"]').first()).toContainText('Energy')"}], "full_test": "await page.fill('[data-testid=\"search-input\"]', 'energy');\nawait expect(page.locator('[data-testid=\"result-row\"]')).toHaveCount(2);\nawait expect(page.locator('[data-testid=\"result-row\"]').first()).toContainText('Energy');"}
{"test_goal": "Verify clicking retry reloads data after transient error", "flow_type": "error_recovery", "assertions": [{"type": "error_banner_shown", "playwright": "await expect(page.locator('[data-testid=\"error-banner\"]')).toBeVisible()"}, {"type": "click_retry", "playwright": "await page.click('[data-testid=\"retry-btn\"]')"}, {"type": "list_visible", "playwright": "await expect(page.locator('[data-testid=\"bills-list\"]')).toBeVisible()"}], "full_test": "await expect(page.locator('[data-testid=\"error-banner\"]')).toBeVisible();\nawait page.click('[data-testid=\"retry-btn\"]');\nawait expect(page.locator('[data-testid=\"bills-list\"]')).toBeVisible();"}
{"test_goal": "Verify onboarding modal can be dismissed", "flow_type": "modal_interaction", "assertions": [{"type": "open_modal", "playwright": "await page.click('[data-testid=\"open-onboarding\"]')"}, {"type": "modal_visible", "playwright": "await expect(page.locator('[data-testid=\"onboarding-modal\"]')).toBeVisible()"}, {"type": "dismiss_modal", "playwright": "await page.click('[data-testid=\"close-modal\"]')"}, {"type": "modal_hidden", "playwright": "await expect(page.locator('[data-testid=\"onboarding-modal\"]')).not.toBeVisible()"}], "full_test": "await page.click('[data-testid=\"open-onboarding\"]');\nawait expect(page.locator('[data-testid=\"onboarding-modal\"]')).toBeVisible();\nawait page.click('[data-testid=\"close-modal\"]');\nawait expect(page.locator('[data-testid=\"onboarding-modal\"]')).not.toBeVisible();"}
{"test_goal": "Verify empty state shows when no bills match the filter", "flow_type": "empty_state", "assertions": [{"type": "apply_filter", "playwright": "await page.fill('[data-testid=\"search-input\"]', 'zzzz')"}, {"type": "empty_message_visible", "playwright": "await expect(page.locator('[data-testid=\"empty-state\"]')).toBeVisible()"}], "full_test": "await page.fill('[data-testid=\"search-input\"]', 'zzzz');\nawait expect(page.locator('[data-testid=\"empty-state\"]')).toBeVisible();"}
