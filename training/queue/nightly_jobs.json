{
  "jobs": [
    {
      "project": "billwatch",
      "task": "summarization",
      "version": "nightly-billwatch-summary",
      "engine": "hf",
      "base_model": "unsloth/phi-3-mini-4k-instruct",
      "epochs": 1,
      "batch_size": 1,
      "learning_rate": 0.00015,
      "ab_gate_baseline_model": "phi3-local",
      "ab_gate_candidate_model": "mistral-local",
      "ab_gate_limit": 30
    },
    {
      "project": "billwatch",
      "task": "classification",
      "version": "nightly-billwatch-classification",
      "engine": "hf",
      "base_model": "unsloth/phi-3-mini-4k-instruct",
      "epochs": 1,
      "batch_size": 1,
      "learning_rate": 0.00015,
      "ab_gate_baseline_model": "phi3-local",
      "ab_gate_candidate_model": "mistral-local",
      "ab_gate_limit": 30
    },
    {
      "project": "billwatch",
      "task": "impact",
      "version": "nightly-billwatch-impact",
      "engine": "hf",
      "base_model": "unsloth/phi-3-mini-4k-instruct",
      "epochs": 1,
      "batch_size": 1,
      "learning_rate": 0.0001,
      "ab_gate_baseline_model": "phi3-local",
      "ab_gate_candidate_model": "mistral-local",
      "ab_gate_limit": 30
    },
    {
      "project": "billwatch",
      "task": "bill_background",
      "version": "nightly-billwatch-background",
      "engine": "hf",
      "base_model": "unsloth/phi-3-mini-4k-instruct",
      "epochs": 1,
      "batch_size": 1,
      "learning_rate": 0.00008,
      "ab_gate_baseline_model": "phi3-local",
      "ab_gate_candidate_model": "mistral-local",
      "ab_gate_limit": 30
    },
    {
      "project": "billwatch",
      "task": "article_relevance",
      "version": "nightly-billwatch-articles",
      "engine": "hf",
      "base_model": "unsloth/phi-3-mini-4k-instruct",
      "epochs": 1,
      "batch_size": 1,
      "learning_rate": 0.00008,
      "ab_gate_baseline_model": "phi3-local",
      "ab_gate_candidate_model": "mistral-local",
      "ab_gate_limit": 30
    },
    {
      "kind": "agent_run",
      "team": "test-automation",
      "objective": "Assess and build a reliable login and checkout smoke suite",
      "mode": "llm",
      "version": "nightly-agent-run-test-automation",
      "output_json": "training/logs/interventions/agent-run-test-automation.json",
      "materialize_dir": "training/logs/interventions/agent-run-test-automation-artifacts",
      "app_stack": "vue3 + fastapi",
      "test_framework": "playwright",
      "scope": "smoke + regression"
    },
    {
      "kind": "agent_run",
      "team": "gitlark-memdiff",
      "objective": "Reduce memdiff latency while preserving freshness for code-intel queries",
      "mode": "llm",
      "version": "nightly-agent-run-gitlark-memdiff",
      "output_json": "training/logs/interventions/agent-run-gitlark-memdiff.json",
      "materialize_dir": "training/logs/interventions/agent-run-gitlark-memdiff-artifacts",
      "query_type": "code-semantics",
      "freshness_sla_minutes": 30,
      "repo_scope": "gitlark"
    },
    {
      "kind": "agent_benchmark",
      "team": "all",
      "mode": "dry-run",
      "pass_threshold": 0.7,
      "version": "nightly-agent-benchmark",
      "output_json": "training/logs/interventions/agent-team-benchmark.json"
    },
    {
      "kind": "agent_promote",
      "team": "all",
      "version": "nightly-agent-promote",
      "benchmark_report": "training/logs/interventions/agent-team-benchmark.json",
      "thresholds": "configs/agent_team_promotion_thresholds.json",
      "output_json": "training/logs/interventions/agent-team-promotion-decision.json",
      "auto_apply": true,
      "rollout_json": "configs/agent_team_rollout.json",
      "queue_json": "training/queue/agent_team_promotions.json",
      "hold_streak_limit": 3
    }
  ]
}

